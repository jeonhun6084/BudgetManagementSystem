# 三井住友銀行 (SMBC) 認証情報
# 通帳・キャッシュカードに記載の情報を入力
SMBC_BRANCH_CODE=      # 지점번호 (支店番号) — 3자리 숫자
SMBC_ACCOUNT_NUMBER=   # 계좌번호 (口座番号) — 7자리 숫자
SMBC_PASSWORD=         # 로그인 비밀번호 (ログインパスワード)

# Vpass (三井住友カード) 認証情報
VPASS_USER_ID=
VPASS_PASSWORD=

# 楽楽清算 認証情報
RAKURAKU_LOGIN_ID=
RAKURAKU_PASSWORD=
RAKURAKU_COMPANY_CODE=

# AI分析 (Google Gemini API — 무료: aistudio.google.com)
GEMINI_API_KEY=

# アプリ設定
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite+aiosqlite:///./budget.db
